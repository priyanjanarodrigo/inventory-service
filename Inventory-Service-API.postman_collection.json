			"item": [
				{
					"name": "Create Customer",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has Location header\", function () {",
									"    pm.response.to.have.header(\"Location\");",
									"});",
									"",
									"pm.test(\"Response body has success status\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.metaData.status).to.eql(\"SUCCESS\");",
									"});",
									"",
									"pm.test(\"Customer ID is returned\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.id).to.be.a('number');",
									"    pm.environment.set(\"customerId\", jsonData.data.id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"address\": \"123 Main Street, New York, NY 10001\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/customers",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"customers"
							]
						},
						"description": "Creates a new customer with the provided details. All fields except address are required."
					},
					"response": []
